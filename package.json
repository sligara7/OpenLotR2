{
  "name": "openlotr2",
  "title": "Open Lords of the Realm2",
  "homepage": "https://github.com/s-ayers/OpenLotR2",
  "version": "0.0.1-alpha",
  "description": "Open Lords of the Realm 2",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "dev:web": "VITE_NO_ELECTRON=1 vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --windows",
    "dist:mac": "npm run build && electron-builder --mac",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "sim": "tsx src/game/demo.ts",
    "test:sim": "tsx src/game/tests/run.ts",
    "test:api": "tsx src/server/tests/run.mts",
    "test:e2e": "playwright test",
    "api": "tsx src/server/index.ts",
    "api:dev": "tsx watch src/server/index.ts"
  },
  "keywords": [
    "phaser",
    "express",
    "electron"
  ],
  "author": "Steve Ayers",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=10.9.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "about-window": "^1.15.2",
    "bufferutil": "^4.0.1",
    "express": "^4.17.1",
    "io": "^1.0.0",
    "nedb": "^1.8.0",
    "phaser": "^3.90.0",
    "pl8image": "github:s-ayers/pl8image",
    "png-crop": "^0.0.2",
    "socket.io": "^2.2.0",
    "source-map-support": "^0.5.13",
    "swagger-ui-express": "^5.0.1",
    "utf-8-validate": "^5.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.21",
    "@types/swagger-ui-express": "^4.1.8",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "typescript": "5.9",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4"
  }
}
